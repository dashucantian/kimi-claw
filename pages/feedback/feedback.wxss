/**pages/feedback/feedback.wxss**/
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0A1628 0%, #1a2540 100%);
  padding: 0 20px 40px;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

/* 完成头部 */
.completion-header {
  text-align: center;
  padding: 40px 0;
}

.completion-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.completion-title {
  display: block;
  font-size: 28px;
  font-weight: 600;
  color: #F5F1E8;
  margin-bottom: 8px;
}

.completion-info {
  display: block;
  font-size: 14px;
  color: rgba(245, 241, 232, 0.5);
}

/* 评分 */
.rating-section {
  margin-bottom: 32px;
}

.section-label {
  display: block;
  font-size: 14px;
  color: rgba(245, 241, 232, 0.6);
  margin-bottom: 16px;
}

.stars {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin-bottom: 12px;
}

.star {
  font-size: 40px;
  color: rgba(245, 241, 232, 0.2);
  transition: all 0.2s;
}

.star.active {
  color: #E8A87C;
}

.rating-text {
  display: block;
  text-align: center;
  font-size: 14px;
  color: #88B0A8;
  min-height: 20px;
}

/* 反馈标签 */
.feedback-tags-section {
  margin-bottom: 32px;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.tag {
  padding: 10px 20px;
  background: rgba(245, 241, 232, 0.05);
  border-radius: 20px;
  font-size: 14px;
  color: rgba(245, 241, 232, 0.7);
  border: 1px solid transparent;
  transition: all 0.2s;
}

.tag.selected {
  background: rgba(107, 91, 149, 0.2);
  border-color: #6B5B95;
  color: #6B5B95;
}

/* 备注 */
.notes-section {
  margin-bottom: 40px;
  position: relative;
}

.notes-input {
  width: 100%;
  height: 120px;
  background: rgba(245, 241, 232, 0.05);
  border-radius: 12px;
  padding: 16px;
  font-size: 14px;
  color: #F5F1E8;
  box-sizing: border-box;
  border: none;
}

.notes-input::placeholder {
  color: rgba(245, 241, 232, 0.3);
}

.notes-count {
  position: absolute;
  bottom: 12px;
  right: 12px;
  font-size: 12px;
  color: rgba(245, 241, 232, 0.4);
}

/* 按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.save-btn {
  width: 100%;
  padding: 16px;
  background: linear-gradient(135deg, #6B5B95 0%, #4a3d6b 100%);
  border-radius: 25px;
  border: none;
  font-size: 16px;
  font-weight: 500;
  color: #F5F1E8;
}

.skip-btn {
  width: 100%;
  padding: 16px;
  background: transparent;
  border-radius: 25px;
  border: 1px solid rgba(245, 241, 232, 0.2);
  font-size: 14px;
  color: rgba(245, 241, 232, 0.5);
}
