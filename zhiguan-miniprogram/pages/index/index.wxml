/**pages/index/index.wxml**/
<view class="page-container">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  
  <!-- 头部问候 -->
  <view class="header">
    <text class="greeting">{{greeting}}</text>
    <text class="sub-greeting">每日止观，回归当下</text>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-number">{{todayCount}}</text>
      <text class="stat-label">今日练习</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{streak}}</text>
      <text class="stat-label">连续天数</text>
    </view>
  </view>

  <!-- 主操作区 - 呼吸圆环 -->
  <view class="main-action">
    <view class="breath-ring-container" bindtap="startPractice">
      <view class="breath-ring {{breathing ? '' : 'paused'}}"></view>
      <view class="glass-center">
        <text class="main-btn-text">开始止观</text>
        <text class="main-btn-sub">点击开始</text>
      </view>
    </view>

    <text class="current-setting">{{duration}}分钟 · {{mode === 'guided' ? '引导' : '自主'}}</text>
  </view>

  <!-- 音频选择 -->
  <view class="section-title">背景音效</view>
  <view class="mode-selector" style="margin-bottom: 24px;">
    <view 
      class="mode-option {{audioType === 'windchime' ? 'active' : ''}}"
      bindtap="selectAudio"
      data-audio="windchime"
    >风铃</view>
    <view 
      class="mode-option {{audioType === 'waterdrop' ? 'active' : ''}}"
      bindtap="selectAudio"
      data-audio="waterdrop"
    >水滴</view>
    <view 
      class="mode-option {{audioType === 'none' ? 'active' : ''}}"
      bindtap="selectAudio"
      data-audio="none"
    >静音</view>
  </view>

  <!-- 时长选择 -->
  <view class="section-title">选择时长</view>
  <view class="duration-selector">
    <view 
      class="duration-option {{duration === 3 ? 'active' : ''}}"
      bindtap="selectDuration"
      data-duration="3"
    >
      <text class="duration-num">3</text>
      <text class="duration-unit">分钟</text>
    </view>
    <view 
      class="duration-option {{duration === 5 ? 'active' : ''}}"
      bindtap="selectDuration"
      data-duration="5"
    >
      <text class="duration-num">5</text>
      <text class="duration-unit">分钟</text>
    </view>
    <view 
      class="duration-option {{duration === 15 ? 'active' : ''}}"
      bindtap="selectDuration"
      data-duration="15"
    >
      <text class="duration-num">15</text>
      <text class="duration-unit">分钟</text>
    </view>
  </view>

  <!-- 模式选择 -->
  <view class="section-title">练习模式</view>
  <view class="mode-selector">
    <view 
      class="mode-option {{mode === 'guided' ? 'active' : ''}}"
      bindtap="selectMode"
      data-mode="guided"
    >引导</view>
    <view 
      class="mode-option {{mode === 'silent' ? 'active' : ''}}"
      bindtap="selectMode"
      data-mode="silent"
    >自主</view>
  </view>
</view>
