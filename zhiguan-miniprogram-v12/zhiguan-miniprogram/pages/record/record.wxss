/**pages/record/record.wxss**/
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  padding: 0 20px 30px;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

.header {
  padding-top: 10px;
  margin-bottom: 24px;
}

.title {
  display: block;
  font-size: 24px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4px;
}

.subtitle {
  display: block;
  font-size: 14px;
  color: rgba(255, 255, 255, 0.5);
}

/* 概览卡片 */
.overview-cards {
  display: flex;
  gap: 10px;
  margin-bottom: 30px;
}

.overview-card {
  flex: 1;
  background: linear-gradient(135deg, rgba(74, 158, 255, 0.2) 0%, rgba(53, 122, 189, 0.1) 100%);
  border-radius: 16px;
  padding: 16px 8px;
  text-align: center;
  border: 1px solid rgba(74, 158, 255, 0.2);
}

.overview-number {
  display: block;
  font-size: 28px;
  font-weight: 700;
  color: #4a9eff;
}

.overview-label {
  display: block;
  font-size: 11px;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 4px;
}

/* 日历 */
.calendar-section {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 24px;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.calendar-title {
  font-size: 14px;
  color: #fff;
  font-weight: 500;
}

.calendar-nav {
  color: rgba(255, 255, 255, 0.5);
  font-size: 14px;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8px;
  text-align: center;
}

.calendar-day-header {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.4);
  padding: 8px 0;
}

.calendar-day {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  color: rgba(255, 255, 255, 0.6);
  position: relative;
  border-radius: 50%;
}

.calendar-day.active {
  background: #4a9eff;
  color: #fff;
}

.calendar-day.today {
  color: #4a9eff;
  font-weight: 600;
  border: 1px solid #4a9eff;
}

.calendar-summary {
  text-align: center;
  font-size: 13px;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

/* 历史记录 */
.history-section {
  flex: 1;
}

.history-title {
  display: block;
  font-size: 16px;
  color: #fff;
  margin-bottom: 12px;
  font-weight: 500;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.history-item {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  padding: 14px;
  display: flex;
  align-items: center;
  gap: 14px;
}

.history-date {
  text-align: center;
  min-width: 44px;
}

.history-day {
  display: block;
  font-size: 22px;
  font-weight: 600;
  color: #4a9eff;
  line-height: 1;
}

.history-month {
  display: block;
  font-size: 10px;
  color: rgba(255, 255, 255, 0.5);
}

.history-info {
  flex: 1;
}

.history-duration {
  display: block;
  font-size: 15px;
  color: #fff;
  margin-bottom: 2px;
}

.history-mode {
  display: block;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.5);
}

.history-rating {
  color: #ffc107;
  font-size: 12px;
  letter-spacing: 2px;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60px 20px;
}

.empty-icon {
  display: block;
  font-size: 48px;
  margin-bottom: 15px;
}

.empty-text {
  display: block;
  font-size: 18px;
  color: #fff;
  margin-bottom: 8px;
}

.empty-sub {
  display: block;
  font-size: 14px;
  color: rgba(255, 255, 255, 0.5);
}