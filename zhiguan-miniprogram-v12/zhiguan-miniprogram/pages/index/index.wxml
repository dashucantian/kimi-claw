/**pages/index/index.wxml**/
<view class="page-container">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  
  <!-- 头部问候 -->
  <view class="header">
    <text class="greeting">{{greeting}}</text>
    <text class="sub-greeting">每日止观，回归当下</text>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-number">{{todayCount}}</text>
      <text class="stat-label">今日练习</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{streak}}</text>
      <text class="stat-label">连续天数</text>
    </view>
  </view>

  <!-- 主操作区 - 呼吸光球 -->
  <view class="main-action">
    <view class="breath-ring-container" bindtap="startPractice">
      <!-- 呼吸光球 -->
      <view class="breath-ring {{breathing ? '' : 'paused'}}">
        <view class="breath-ring-inner">
          <text class="breath-text">止 观</text>
          <text class="breath-hint">点击开始</text>
        </view>
        <!-- 粒子效果 -->
        <view class="particles">
          <view class="particle" style="top: 10%; left: 20%; animation-delay: 0s;"></view>
          <view class="particle" style="top: 30%; left: 80%; animation-delay: 1s;"></view>
          <view class="particle" style="top: 70%; left: 15%; animation-delay: 2s;"></view>
          <view class="particle" style="top: 80%; left: 75%; animation-delay: 3s;"></view>
          <view class="particle" style="top: 50%; left: 90%; animation-delay: 1.5s;"></view>
        </view>
      </view>
    </view>

    <text class="current-setting">{{duration}}分钟</text>
  </view>

  <!-- 时长选择 -->
  <view class="section-title">选择时长</view>
  <view class="duration-selector">
    <view 
      class="duration-option {{duration === 3 ? 'active' : ''}}"
      bindtap="selectDuration"
      data-duration="3"
    >
      <text class="duration-num">3</text>
      <text class="duration-unit">分钟</text>
    </view>
    <view 
      class="duration-option {{duration === 5 ? 'active' : ''}}"
      bindtap="selectDuration"
      data-duration="5"
    >
      <text class="duration-num">5</text>
      <text class="duration-unit">分钟</text>
    </view>
    <view 
      class="duration-option {{duration === 15 ? 'active' : ''}}"
      bindtap="selectDuration"
      data-duration="15"
    >
      <text class="duration-num">15</text>
      <text class="duration-unit">分钟</text>
    </view>
  </view>
</view>
