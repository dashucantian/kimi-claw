/**pages/profile/profile.wxss**/
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0A1628 0%, #1a2540 100%);
  padding: 0 20px 30px;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

/* 顶部标题栏 */
.top-bar {
  padding: 0 20px;
  text-align: center;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.top-bar-title {
  font-size: 10px;
  color: rgba(245, 241, 232, 0.5);
  letter-spacing: 0.5px;
  border-bottom: 1px solid rgba(245, 241, 232, 0.15);
  padding-bottom: 2px;
  padding-left: 20px;
  padding-right: 20px;
}

/* 用户信息 */
.profile-header {
  text-align: center;
  padding: 30px 0;
}

.avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: linear-gradient(135deg, #6B5B95 0%, #4a3d6b 100%);
  margin: 0 auto 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
}

.profile-name {
  display: block;
  font-size: 20px;
  color: #F5F1E8;
  font-weight: 600;
  margin-bottom: 4px;
}

.profile-join {
  display: block;
  font-size: 12px;
  color: rgba(245, 241, 232, 0.5);
}

/* 设置列表 */
.settings-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.setting-item {
  background: rgba(245, 241, 232, 0.05);
  border-radius: 12px;
  padding: 16px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.setting-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: rgba(107, 91, 149, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

.setting-content {
  flex: 1;
}

.setting-title {
  display: block;
  font-size: 15px;
  color: #F5F1E8;
  margin-bottom: 2px;
}

.setting-subtitle {
  display: block;
  font-size: 12px;
  color: rgba(245, 241, 232, 0.5);
}

.setting-arrow {
  color: rgba(245, 241, 232, 0.3);
  font-size: 18px;
}

.setting-switch {
  transform: scale(0.8);
}
