/* pages/stats/stats.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0A1628 0%, #1a2540 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #F5F1E8;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(245, 241, 232, 0.5);
}

/* 总览卡片 */
.overview-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: linear-gradient(135deg, rgba(107, 91, 149, 0.2) 0%, rgba(107, 91, 149, 0.1) 100%);
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid rgba(107, 91, 149, 0.2);
}

.overview-item {
  text-align: center;
  flex: 1;
}

.overview-number {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #88B0A8;
  margin-bottom: 8rpx;
}

.overview-label {
  font-size: 24rpx;
  color: rgba(245, 241, 232, 0.6);
}

.overview-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(245, 241, 232, 0.1);
}

/* 区块 */
.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #F5F1E8;
}

.section-subtitle {
  font-size: 24rpx;
  color: rgba(245, 241, 232, 0.5);
}

.clear-btn {
  font-size: 24rpx;
  color: #f44336;
  padding: 10rpx 20rpx;
}

/* 周历 */
.week-calendar {
  display: flex;
  justify-content: space-between;
  background: rgba(245, 241, 232, 0.05);
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
}

.day-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.day-name {
  font-size: 22rpx;
  color: rgba(245, 241, 232, 0.5);
}

.day-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(245, 241, 232, 0.1);
}

.day-item.active .day-dot {
  background: #6B5B95;
  box-shadow: 0 0 20rpx rgba(107, 91, 149, 0.5);
}

.day-count {
  font-size: 20rpx;
  color: #88B0A8;
}

/* 历史记录 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  background: rgba(245, 241, 232, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
}

.history-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.history-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 80rpx;
}

.date-day {
  font-size: 36rpx;
  font-weight: 600;
  color: #88B0A8;
}

.date-month {
  font-size: 20rpx;
  color: rgba(245, 241, 232, 0.5);
}

.history-info {
  flex: 1;
}

.history-duration {
  display: block;
  font-size: 30rpx;
  color: #F5F1E8;
  margin-bottom: 4rpx;
}

.history-mode {
  font-size: 22rpx;
  color: rgba(245, 241, 232, 0.5);
}

.history-rating {
  min-width: 100rpx;
  text-align: right;
}

.rating-stars {
  font-size: 28rpx;
  color: #E8A87C;
}

.history-notes {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(245, 241, 232, 0.1);
}

.history-notes text {
  font-size: 26rpx;
  color: rgba(245, 241, 232, 0.7);
  line-height: 1.5;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  background: rgba(245, 241, 232, 0.03);
  border-radius: 16rpx;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #F5F1E8;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: rgba(245, 241, 232, 0.5);
}

/* 底部提示 */
.footer-tips {
  text-align: center;
  padding: 40rpx;
}

.footer-tips text {
  font-size: 24rpx;
  color: rgba(245, 241, 232, 0.4);
}
